<%- include('partials/header') %>

<h2>Админ-панель - Управление записями</h2>

<div class="bookings-list">
    <table>
        <thead>
            <tr>
                <th>Клиент</th>
                <th>Телефон</th>
                <th>Услуга</th>
                <th>Дата</th>
                <th>Время</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            <% if (bookings.length === 0) { %>
            <tr>
                <td colspan="6" style="text-align: center;">Нет записей</td>
            </tr>
            <% } else { %>
                <% bookings.forEach(booking => { %>
                <tr>
                    <td><%= booking.clientName %></td>
                    <td><%= booking.phone %></td>
                    <td><%= booking.serviceId ? booking.serviceId.name : 'Не указана' %></td>
                    <td><%= booking.date %></td>
                    <td><%= booking.time %></td>
                    <td>
                        <form action="/admin/delete/<%= booking._id %>" method="POST" style="display: inline;">
                            <button type="submit" class="btn-delete" onclick="return confirm('Удалить запись?')">Удалить</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('partials/footer') %>